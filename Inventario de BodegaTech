-- DDL Paso 1 borrar tabla inventario
DROP TABLE IF EXISTS inventario;

-- Paso 2 crear tabla inventario con sus columnas
CREATE TABLE inventario (
-- Identificador de productos unico
Id_producto INT PRIMARY KEY,
-- nombre de cada producto hasta 100 caracteres
nombre_producto VARCHAR (100),
-- categoria de distincion de producto hasta 50 carateres
categoria VARCHAR(50),
-- Precio de venta en USD del producto, hasta dos decimales
precio_unitario DECIMAL(10,2),
-- Cantidad de unidades disponibles al momento, en numero entero
stock_actual INT,
-- Cantidad de unidades minimas para su reposicion, en numero entero
stock_minimo INT,
-- Fecha de ingreso de las unidades al inventario, sin hora
fecha_ingreso DATE,
-- Disponibilidad de unidades en el inventario, TRUE = disponible, FALSE = descontinuado
activo BOOLEAN
);


